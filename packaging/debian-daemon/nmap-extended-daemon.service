[Unit]
Description=Nmap Extended Daemon
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
Group=root
Environment=NMAPDIR=/usr/share/nmap_extended
ExecStart=/usr/bin/nmap_extended --service --service-config /etc/nmap_extended/service_config.json
Restart=on-failure
RestartSec=2
NoNewPrivileges=true
PrivateTmp=true
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
